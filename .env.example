PORT=3000
NODE_ENV=development

DATABASE_URL="postgresql://postgres@localhost:5432/postgres?schema=public"
JWT_ACCESS_SECRET=""
# Access JWT `iss` / `aud` (must match between signing and JwtStrategy).
JWT_ISSUER="https://api.example.com"
JWT_AUDIENCE="https://app.example.com"
# Optional; default "1m". Same string drives JWT expiry and access cookie maxAge.
# JWT_ACCESS_TTL="15m"
# Optional refresh TTLs (defaults: 14d web, 90d mobile, 180d absolute chain cap).
# REFRESH_TOKEN_TTL_WEB="5m"
# REFRESH_TOKEN_TTL_MOBILE="90d"
# REFRESH_TOKEN_ABSOLUTE_MAX="180d"
COOKIE_SECRET=""
# Variant B: cookies are host-only on the Next app origin (no Domain). Leave COOKIE_DOMAIN empty.
# COOKIE_DOMAIN=".example.com"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Must match the public URL (Next /api rewrite), e.g. app :3001 → /api/auth/google/callback
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"
FRONTEND_URL="http://localhost:3001"
# Optional: extra CORS origins (comma-separated). FRONTEND_URL is always allowed.
# CORS_URL="https://www.example.com"
CLOUD_FLARE_TURNSTILE_SECRET_KEY="dssddssdsdsdad12e12"
REDIS_URL=""